{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/assets/:path*",
      "destination": "/public/assets/:path*"
    },
    {
      "source": "/(favicon.svg|icons.svg|vite.svg|logo.png)",
      "destination": "/public/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/public/index.html"
    }
  ]
}
